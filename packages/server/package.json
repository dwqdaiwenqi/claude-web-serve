{
  "name": "@claude-web/server",
  "version": "0.1.23",
  "description": "HTTP API server for Claude Code Agent SDK",
  "type": "module",
  "bin": {
    "claude-web": "./dist/cli.js"
  },
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "public",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "NODE_ENV=development tsx watch src/cli.ts start",
    "start": "node dist/cli.js start",
    "typecheck": "tsc --noEmit",
    "rebuild:pty": "npm rebuild node-pty",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "ai",
    "agent",
    "api",
    "server"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dwqdaiwenqi/claude-web-serve.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/dwqdaiwenqi/claude-web-serve#readme",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.114",
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^11.2.0",
    "commander": "^13.1.0",
    "fastify": "^5.8.5",
    "node-pty": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.5",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "cross-env": "^10.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
